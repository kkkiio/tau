{
  "name": "tau-mirror",
  "version": "1.0.7",
  "description": "Web UI that mirrors your Pi terminal session in the browser",
  "keywords": [
    "pi",
    "pi-package",
    "coding-agent",
    "web-ui",
    "mirror"
  ],
  "author": "deflating",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deflating/tau.git"
  },
  "pi": {
    "extensions": [
      "./extensions/mirror-server.ts"
    ],
    "image": "https://raw.githubusercontent.com/deflating/tau/main/docs/images/dark.png"
  },
  "scripts": {
    "dev:web": "vite --host 127.0.0.1",
    "build:web": "tsc --noEmit && vite build",
    "preview:web": "vite preview --host 127.0.0.1",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "ci:biome": "biome ci .",
    "prepare": "npm run build:web",
    "prepack": "npm run build:web"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.193",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.191",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "qrcode": "^1.5.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "^4.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
